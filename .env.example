TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_ALLOWED_USER_IDS=123456789

# Codex runtime options
CODEX_MODEL=gpt-5.4
CODEX_SANDBOX=workspace_write
CODEX_WORKDIR=/home/ubuntu/agent-workspace

# Telegram UX
TELEGRAM_MAX_RESPONSE_CHARS=3900
TELEGRAM_HEARTBEAT_SECONDS=30

# Runtime resilience
CODEX_TIMEOUT_SECONDS=300
CODEX_CLI_FALLBACK=false

# Optional Cosmic Graph Intelligence harness
# Start ~/CGI/CGI_Cosmic_Graph_Intelligence first:
#   pip install -r requirements.txt
#   LLM_PROVIDER=codex LLM_MODEL=gpt-5.5 CODEX_WORKDIR=/home/ubuntu/CGI/CGI_Cosmic_Graph_Intelligence uvicorn app.main:app --host 127.0.0.1 --port 8000
CGI_HARNESS_ENABLED=false
CGI_HARNESS_ENDPOINT=http://127.0.0.1:8000/api/chat
CGI_HARNESS_MODE=balanced
CGI_HARNESS_TIMEOUT_SECONDS=240
CGI_HARNESS_MAX_REPORT_CHARS=8000

# CGI SQLite memory (stored by the CGI service, not my-agent)
CGI_MEMORY_ENABLED=true
CGI_MEMORY_DB_PATH=/home/ubuntu/CGI/CGI_Cosmic_Graph_Intelligence/data/cgi_memory.sqlite3
CGI_MEMORY_CONTEXT_LIMIT=12

# Persistence
SQLITE_PATH=/home/ubuntu/apps/my-agent/data/agent.sqlite3

